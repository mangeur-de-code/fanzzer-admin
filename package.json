{
  "name": "fanzzer-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.toml --port 8788",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy --config wrangler.toml",
    "deploy:production": "wrangler deploy --config wrangler.toml --env production",
    "cf-typegen": "wrangler types --config wrangler.toml -o src/worker-configuration.d.ts"
  },
  "dependencies": {
    "@clerk/backend": "^1.16.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.78.0"
  }
}